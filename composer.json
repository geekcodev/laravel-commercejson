{
  "name": "geekcodev/laravel-commercejson",
  "description": "CommerceJSON v1.0.8 integration package for Laravel 12",
  "type": "library",
  "homepage": "https://github.com/geekcodev/laravel-commercejson",
  "license": "MIT",
  "keywords": [
    "laravel",
    "package",
    "commercejson"
  ],
  "authors": [
    {
      "name": "Evgeny Semenov",
      "email": "geekco@yandex.ru",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "laravel/framework": "^v13.0",
    "spatie/laravel-data": "^4.0",
    "guzzlehttp/guzzle": "^7.9",
    "symfony/yaml": "^8.0"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "orchestra/testbench": "^11.0",
    "pestphp/pest": "*",
    "phpstan/phpstan": "^1.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "GeekCo\\CommerceJson\\": "src/",
      "GeekCo\\CommerceJson\\Database\\Factories\\": "src/database/factories/",
      "GeekCo\\CommerceJson\\Database\\Seeders\\": "src/database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "GeekCo\\CommerceJson\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "GeekCo\\CommerceJson\\CommerceJsonServiceProvider"
      ],
      "aliases": {
        "CommerceJson": "GeekCo\\CommerceJson\\Facades\\CommerceJson"
      }
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true,
      "pestphp/pest-plugin": true
    }
  },
  "scripts": {
    "test": "php vendor/bin/pest",
    "test:coverage": "php vendor/bin/pest --coverage-html=coverage --coverage-clover=coverage.xml",
    "test:coverage-text": "php vendor/bin/pest --coverage-text",
    "analyse": "php -d memory_limit=512M vendor/bin/phpstan analyse src/",
    "format": "pint",
    "format:test": "pint --test"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
